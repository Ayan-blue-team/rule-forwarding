{
  "rule": {
    "id": "SEC-009",
    "name": "SEC-009 | AD Password Never Expires Set",
    "description": "Monitors Windows Event ID 4738 - Password never expires flag set on user account",
    "type": "EVENT",
    "enabled": true,
    "group": "Authentication",
    "notes": "Monitors Windows Event ID 4738 - Password never expires set. Common attacker persistence technique!",

    "conditions": {
      "operator": "AND",
      "tests": [
        {
          "test_name": "EventQIDTest",
          "description": "Match User Account Changed QID",
          "qids": [
            { "qid": 5000908, "name": "Success Audit: A user account was changed" }
          ]
        },
        {
          "test_name": "PayloadTest",
          "description": "Check for Password Never Expires flag",
          "payload_contains": "Don't Expire Password"
        }
      ]
    },

    "actions": {
      "severity": 7,
      "credibility": 8,
      "relevance": 8,
      "ensure_offense": true,
      "index_offense_by": "Username",
      "annotate_event": "Password Never Expires Set - Possible Persistence Attempt!",
      "dispatch_new_event": true,
      "dispatch_event_details": {
        "event_name": "SOC-QR-009: Password Never Expires Set",
        "event_description": "Password never expires flag set on AD account - Investigate for persistence attempt",
        "severity": 7,
        "credibility": 8,
        "relevance": 8,
        "high_level_category": "Authentication",
        "low_level_category": "User Account Changed"
      },
      "notify": true
    },

    "response_limiter": {
      "enabled": true,
      "max_responses": 1,
      "interval": 10,
      "interval_unit": "minutes",
      "per": "Username"
    },

    "metadata": {
      "created_by": "SOC Team",
      "created_date": "2026-04-22",
      "version": "1.0",
      "log_source": "WindowsAuthServer @ DC-01",
      "mitre_attack": {
        "tactic": "Persistence",
        "technique": "T1098",
        "technique_name": "Account Manipulation"
      },
      "windows_event_ids": ["4738"],
      "log_sources": [
        "Microsoft Windows Security Event Log",
        "WindowsAuthServer @ DC-01"
      ],
      "tested": false,
      "test_date": null,
      "domain": "AZINTELECOM"
    }
  }
}
