{
  "rule": {
    "id": "SEC-007",
    "name": "SEC-007 | AD User Account Locked Out",
    "description": "Monitors Windows Event ID 4740 - User account locked out in AD",
    "type": "EVENT",
    "enabled": true,
    "group": "Authentication",
    "notes": "Monitors Windows Event ID 4740 - User account locked out in AD",

    "conditions": {
      "operator": "AND",
      "tests": [
        {
          "test_name": "EventQIDTest",
          "description": "Match User Account Locked Out QID",
          "qids": [
            { "qid": 5000903, "name": "Success Audit: A user account was locked out" }
          ]
        }
      ]
    },

    "actions": {
      "severity": 7,
      "credibility": 8,
      "relevance": 8,
      "ensure_offense": true,
      "index_offense_by": "Username",
      "annotate_event": "AD User Account Locked Out - Possible Brute Force!",
      "dispatch_new_event": true,
      "dispatch_event_details": {
        "event_name": "SOC-QR-007: User Account Locked Out",
        "event_description": "AD user account locked out - Possible brute force attack",
        "severity": 7,
        "credibility": 8,
        "relevance": 8,
        "high_level_category": "Authentication",
        "low_level_category": "User Account Locked"
      },
      "notify": true
    },

    "response_limiter": {
      "enabled": true,
      "max_responses": 1,
      "interval": 10,
      "interval_unit": "minutes",
      "per": "Username"
    },

    "metadata": {
      "created_by": "SOC Team",
      "created_date": "2026-04-22",
      "version": "1.0",
      "log_source": "WindowsAuthServer @ DC-01",
      "mitre_attack": {
        "tactic": "Credential Access",
        "technique": "T1110",
        "technique_name": "Brute Force"
      },
      "windows_event_ids": ["4740"],
      "log_sources": [
        "Microsoft Windows Security Event Log",
        "WindowsAuthServer @ DC-01"
      ],
      "tested": false,
      "test_date": null,
      "domain": "AZINTELECOM"
    }
  }
}
