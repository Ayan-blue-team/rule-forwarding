{
  "rule": {
    "id": "SEC-008",
    "name": "SEC-008 | AD Password Changed",
    "description": "Monitors Windows Event ID 4723/4724 - User password changed in AD",
    "type": "EVENT",
    "enabled": true,
    "group": "Authentication",
    "notes": "Monitors Windows Event ID 4723 (user changes own password) and 4724 (admin resets password)",

    "conditions": {
      "operator": "AND",
      "tests": [
        {
          "test_name": "EventQIDTest",
          "description": "Match Password Changed QIDs",
          "qids": [
            { "qid": 5000896, "name": "Success Audit: An attempt was made to change an account password" },
            { "qid": 5000894, "name": "Success Audit: An attempt was made to reset an accounts password" }
          ]
        }
      ]
    },

    "actions": {
      "severity": 5,
      "credibility": 8,
      "relevance": 8,
      "ensure_offense": true,
      "index_offense_by": "Username",
      "annotate_event": "AD Password Changed - Verify if authorized!",
      "dispatch_new_event": true,
      "dispatch_event_details": {
        "event_name": "SOC-QR-008: Password Changed",
        "event_description": "AD user password was changed or reset - Verify if authorized",
        "severity": 5,
        "credibility": 8,
        "relevance": 8,
        "high_level_category": "Authentication",
        "low_level_category": "Password Change Succeeded"
      },
      "notify": true
    },

    "response_limiter": {
      "enabled": true,
      "max_responses": 1,
      "interval": 10,
      "interval_unit": "minutes",
      "per": "Username"
    },

    "metadata": {
      "created_by": "SOC Team",
      "created_date": "2026-04-22",
      "version": "1.0",
      "log_source": "WindowsAuthServer @ DC-01",
      "mitre_attack": {
        "tactic": "Credential Access",
        "technique": "T1098",
        "technique_name": "Account Manipulation"
      },
      "windows_event_ids": ["4723", "4724"],
      "log_sources": [
        "Microsoft Windows Security Event Log",
        "WindowsAuthServer @ DC-01"
      ],
      "tested": false,
      "test_date": null,
      "domain": "AZINTELECOM"
    }
  }
}
