{
  "rule": {
    "id": "SEC-005",
    "name": "SEC-005 | AD User Account Disabled",
    "description": "Monitors Windows Event ID 4725 - User account disabled in AD",
    "type": "EVENT",
    "enabled": true,
    "group": "Authentication",
    "notes": "Monitors Windows Event ID 4725 - User account disabled in AD",

    "conditions": {
      "operator": "AND",
      "tests": [
        {
          "test_name": "EventQIDTest",
          "description": "Match User Account Disabled QID",
          "qids": [
            { "qid": 5000895, "name": "Success Audit: A user account was disabled" }
          ]
        }
      ]
    },

    "actions": {
      "severity": 6,
      "credibility": 8,
      "relevance": 8,
      "ensure_offense": true,
      "index_offense_by": "Username",
      "annotate_event": "AD User Account Disabled - Investigate!",
      "dispatch_new_event": true,
      "dispatch_event_details": {
        "event_name": "SOC-QR-005: User Account Disabled",
        "event_description": "AD user account was disabled - Verify if authorized",
        "severity": 6,
        "credibility": 8,
        "relevance": 8,
        "high_level_category": "Authentication",
        "low_level_category": "User Account Disabled"
      },
      "notify": true
    },

    "response_limiter": {
      "enabled": true,
      "max_responses": 1,
      "interval": 10,
      "interval_unit": "minutes",
      "per": "Username"
    },

    "metadata": {
      "created_by": "SOC Team",
      "created_date": "2026-04-22",
      "version": "1.0",
      "log_source": "WindowsAuthServer @ DC-01",
      "mitre_attack": {
        "tactic": "Impact",
        "technique": "T1531",
        "technique_name": "Account Access Removal"
      },
      "windows_event_ids": ["4725"],
      "log_sources": [
        "Microsoft Windows Security Event Log",
        "WindowsAuthServer @ DC-01"
      ],
      "tested": false,
      "test_date": null,
      "domain": "AZINTELECOM"
    }
  }
}
