{
  "rule": {
    "id": "SEC-006",
    "name": "SEC-006 | AD User Account Enabled",
    "description": "Monitors Windows Event ID 4722 - User account enabled in AD",
    "type": "EVENT",
    "enabled": true,
    "group": "Authentication",
    "notes": "Monitors Windows Event ID 4722 - User account enabled in AD",

    "conditions": {
      "operator": "AND",
      "tests": [
        {
          "test_name": "EventQIDTest",
          "description": "Match User Account Enabled QID",
          "qids": [
            { "qid": 5000893, "name": "Success Audit: A user account was enabled" }
          ]
        }
      ]
    },

    "actions": {
      "severity": 6,
      "credibility": 8,
      "relevance": 8,
      "ensure_offense": true,
      "index_offense_by": "Username",
      "annotate_event": "AD User Account Enabled - Investigate!",
      "dispatch_new_event": true,
      "dispatch_event_details": {
        "event_name": "SOC-QR-006: User Account Enabled",
        "event_description": "AD user account was enabled - Verify if authorized",
        "severity": 6,
        "credibility": 8,
        "relevance": 8,
        "high_level_category": "Authentication",
        "low_level_category": "User Account Unlocked"
      },
      "notify": true
    },

    "response_limiter": {
      "enabled": true,
      "max_responses": 1,
      "interval": 10,
      "interval_unit": "minutes",
      "per": "Username"
    },

    "metadata": {
      "created_by": "SOC Team",
      "created_date": "2026-04-22",
      "version": "1.0",
      "log_source": "WindowsAuthServer @ DC-01",
      "mitre_attack": {
        "tactic": "Persistence",
        "technique": "T1098",
        "technique_name": "Account Manipulation"
      },
      "windows_event_ids": ["4722"],
      "log_sources": [
        "Microsoft Windows Security Event Log",
        "WindowsAuthServer @ DC-01"
      ],
      "tested": false,
      "test_date": null,
      "domain": "AZINTELECOM"
    }
  }
}
