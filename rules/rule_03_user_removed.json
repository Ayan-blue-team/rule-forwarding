{
  "rule": {
    "id": "SEC-003",
    "name": "SEC-003 | AD User Account Deleted",
    "description": "Monitors Windows Event ID 4726 - User account permanently deleted in AD",
    "type": "EVENT",
    "enabled": true,
    "group": "Authentication",
    "notes": "Monitors Windows Event ID 4726 - User account permanently deleted in AD",

    "conditions": {
      "operator": "AND",
      "tests": [
        {
          "test_name": "EventQIDTest",
          "description": "Match User Account Deleted QID",
          "qids": [
            { "qid": 5000897, "name": "Success Audit: A user account was deleted" }
          ]
        }
      ]
    },

    "actions": {
      "severity": 7,
      "credibility": 8,
      "relevance": 8,
      "ensure_offense": true,
      "index_offense_by": "Username",
      "annotate_event": "AD User Account Deleted - Investigate!",
      "dispatch_new_event": true,
      "dispatch_event_details": {
        "event_name": "SOC-QR-003: User Account Deleted",
        "event_description": "AD user account was permanently deleted - Immediate investigation required",
        "severity": 7,
        "credibility": 8,
        "relevance": 8,
        "high_level_category": "Authentication",
        "low_level_category": "User Account Removed"
      },
      "notify": true
    },

    "response_limiter": {
      "enabled": true,
      "max_responses": 1,
      "interval": 10,
      "interval_unit": "minutes",
      "per": "Username"
    },

    "metadata": {
      "created_by": "SOC Team",
      "created_date": "2026-04-22",
      "version": "1.0",
      "log_source": "WindowsAuthServer @ DC-01",
      "mitre_attack": {
        "tactic": "Impact",
        "technique": "T1531",
        "technique_name": "Account Access Removal"
      },
      "windows_event_ids": ["4726"],
      "log_sources": [
        "Microsoft Windows Security Event Log",
        "WindowsAuthServer @ DC-01"
      ],
      "tested": true,
      "test_date": "2026-04-22",
      "domain": "AZINTELECOM"
    }
  }
}
